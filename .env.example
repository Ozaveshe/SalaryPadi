# Local canonical URL used for redirects, metadata and CSRF origin checks.
# Production requires an explicitly configured non-loopback HTTPS origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Create a dedicated SalaryPadi project. Do not use the AfroTools or LATMtools keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dedicated bearer for the scheduled worker to refresh the protected shared
# source snapshot. Generate independently; never reuse a database credential.
JOB_SOURCE_SYNC_TOKEN=

# Server-only AfroTools production API access. Never prefix the key with NEXT_PUBLIC_.
AFROTOOLS_API_BASE_URL=https://afrotools.com/api/v1
AFROTOOLS_API_KEY=

# Supplemental sources stay disabled unless the reviewed source-policy registry
# and environment gate both authorize the exact use.
REMOTIVE_SOURCE_ENABLED=false

# Employer ATS acquisition is an independent emergency gate. Keep false until
# a disabled-by-default database source has written permission, reviewed terms,
# an exact tenant/destination configuration and an approved activation change.
ATS_SOURCE_SYNC_ENABLED=false

# Emergency gate for all editorial scheduled tasks. Set false to stop snapshot,
# drafting, checks, publication, and audits without changing content state.
EDITORIAL_AUTOMATION_ENABLED=true

# Google Search Console is read-only and Google Indexing is job-only. Both are
# disabled by default. The same dedicated service account may be used only after
# Search Console ownership and the relevant Google API permissions are granted.
GOOGLE_SEARCH_CONSOLE_ENABLED=false
GOOGLE_INDEXING_ENABLED=false
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:salarypadi.com
GOOGLE_SEARCH_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SEARCH_SERVICE_ACCOUNT_PRIVATE_KEY=

# Development/test fixtures are opt-in and are rejected when NODE_ENV=production.
ALLOW_DEMO_DATA=false

# Consent-gated first-party aggregate counts in the dedicated Supabase project.
ANALYTICS_PROVIDER=supabase_first_party

# Optional GA4 measurement. The Google tag stays unloaded until explicit consent.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Netlify scheduled alert delivery. Keep the API key in Netlify/Supabase secret
# stores only; never prefix it with NEXT_PUBLIC_ or commit it.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
TRANSACTIONAL_EMAIL_FROM=SalaryPadi <updates@mail.salarypadi.com>
TRANSACTIONAL_EMAIL_REPLY_TO=support@salarypadi.com

# Licensed monthly accounting reference rates with explicit attribution.
CURRENCY_RATE_PROVIDER=european_commission_inforeuro

# Optional isolated browser-test sessions. Generate these only against a
# disposable SalaryPadi test project; the admin session must have AAL2.
E2E_USER_STORAGE_STATE=
E2E_ADMIN_STORAGE_STATE=
