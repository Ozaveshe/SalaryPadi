# Local canonical URL used for redirects, metadata and CSRF origin checks.
# Production requires an explicitly configured non-loopback HTTPS origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Create a dedicated SalaryPadi project. Do not use the AfroTools or LATMtools keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The constrained Remotive pilot is enabled by default. Set false to disable all live feed reads.
REMOTIVE_SOURCE_ENABLED=true

# Development/test fixtures are opt-in and are rejected when NODE_ENV=production.
ALLOW_DEMO_DATA=false

# Optional server-side analytics adapter. The built-in implementation is a privacy-safe no-op.
ANALYTICS_PROVIDER=none

# Optional isolated browser-test sessions. Generate these only against a
# disposable SalaryPadi test project; the admin session must have AAL2.
E2E_USER_STORAGE_STATE=
E2E_ADMIN_STORAGE_STATE=
