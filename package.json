{
  "name": "salarypadi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:netlify": "npm run deploy:verify && npm run build",
    "deploy:verify": "node scripts/verify-deploy-channel.mjs",
    "deploy:preview": "netlify deploy --build",
    "deploy:production": "netlify deploy --prod --build",
    "ops:verify-freshness": "node scripts/verify-production-freshness.mjs",
    "audit:production-truth": "vitest run src/lib/production-truth/audit.test.ts",
    "audit:company-intelligence": "node scripts/audit-company-intelligence-ingress.mjs --check",
    "companies:catalog:build": "node scripts/build-african-company-catalog.mjs",
    "companies:catalog:check": "node scripts/build-african-company-catalog.mjs --check",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:db:remote": "node scripts/run-remote-pgtap.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@netlify/blobs": "10.7.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "he": "^1.2.0",
    "lucide-react": "^1.24.0",
    "next": "^16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "tldts": "7.0.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@netlify/edge-functions": "3.0.8",
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/he": "^1.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "pg": "^8.22.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "postcss": "8.5.10",
    "sharp": "^0.35.3"
  }
}
